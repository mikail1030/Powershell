<#
.SYNOPSIS
    Compares CA_backup_BCKP (source) against CA_backup (destination) and
    reports any files/folders that are missing or differ in size in the destination.
.NOTES
    Run with sufficient permissions to read both trees.
#>

param(
    [string]$SourcePath      = "G:\CA_backup_BCKP",
    [string]$DestinationPath = "G:\CA_backup",
    [string]$ReportPath      = "G:\CA_backup_comparison_report.txt",
    [switch]$CompareHash     # use file hash instead of size for comparison (slower, more accurate)
)

if (-not (Test-Path $SourcePath)) {
    Write-Error "Source path '$SourcePath' does not exist."
    return
}
if (-not (Test-Path $DestinationPath)) {
    Write-Error "Destination path '$DestinationPath' does not exist."
    return
}

Write-Host "Scanning source: $SourcePath ..." -ForegroundColor Cyan
$sourceItems = Get-ChildItem -Path $SourcePath -Recurse -Force -ErrorAction SilentlyContinue

Write-Host "Scanning destination: $DestinationPath ..." -ForegroundColor Cyan
# Build a lookup of destination items by their relative path for fast comparison
$destItems = Get-ChildItem -Path $DestinationPath -Recurse -Force -ErrorAction SilentlyContinue
$destLookup = @{}
foreach ($d in $destItems) {
    $relPath = $d.FullName.Substring($DestinationPath.Length).TrimStart('\')
    $destLookup[$relPath] = $d
}

$missing   = New-Object System.Collections.Generic.List[string]
$different = New-Object System.Collections.Generic.List[string]
$okCount   = 0
$total     = $sourceItems.Count
$counter   = 0

Write-Host "Comparing $total item(s)...`n" -ForegroundColor Cyan

foreach ($item in $sourceItems) {
    $counter++
    if ($counter % 200 -eq 0) {
        Write-Host "Progress: $counter / $total" -ForegroundColor DarkGray
    }

    $relPath = $item.FullName.Substring($SourcePath.Length).TrimStart('\')

    if (-not $destLookup.ContainsKey($relPath)) {
        $missing.Add($relPath)
        continue
    }

    # If it's a file, optionally verify it actually matches (not just "exists")
    if (-not $item.PSIsContainer) {
        $destFile = $destLookup[$relPath]

        if ($destFile.PSIsContainer) {
            # Name collision: source is a file, destination has a folder with same relative path
            $different.Add("$relPath  (source=FILE, destination=FOLDER)")
            continue
        }

        if ($CompareHash) {
            $srcHash  = (Get-FileHash -Path $item.FullName -Algorithm SHA256 -ErrorAction SilentlyContinue).Hash
            $destHash = (Get-FileHash -Path $destFile.FullName -Algorithm SHA256 -ErrorAction SilentlyContinue).Hash
            if ($srcHash -ne $destHash) {
                $different.Add("$relPath  (hash mismatch)")
                continue
            }
        }
        else {
            if ($item.Length -ne $destFile.Length) {
                $different.Add("$relPath  (size mismatch: source=$($item.Length) bytes, destination=$($destFile.Length) bytes)")
                continue
            }
        }
    }

    $okCount++
}

# Build report
$reportLines = New-Object System.Collections.Generic.List[string]
$reportLines.Add("CA_backup comparison report")
$reportLines.Add("Generated: $(Get-Date -Format 'yyyy-MM-dd HH:mm:ss')")
$reportLines.Add("Source:      $SourcePath")
$reportLines.Add("Destination: $DestinationPath")
$reportLines.Add("Comparison mode: $(if ($CompareHash) { 'SHA256 hash' } else { 'file size' })")
$reportLines.Add("")
$reportLines.Add("Total items in source: $total")
$reportLines.Add("OK (present and matching): $okCount")
$reportLines.Add("Missing in destination:    $($missing.Count)")
$reportLines.Add("Present but different:     $($different.Count)")
$reportLines.Add("")
$reportLines.Add("===== MISSING IN DESTINATION =====")
if ($missing.Count -eq 0) {
    $reportLines.Add("(none)")
}
else {
    $reportLines.AddRange($missing)
}
$reportLines.Add("")
$reportLines.Add("===== PRESENT BUT DIFFERENT =====")
if ($different.Count -eq 0) {
    $reportLines.Add("(none)")
}
else {
    $reportLines.AddRange($different)
}

$reportLines | Out-File -FilePath $ReportPath -Encoding UTF8

Write-Host "`nDone." -ForegroundColor Cyan
Write-Host "OK: $okCount | Missing: $($missing.Count) | Different: $($different.Count)" -ForegroundColor Yellow
Write-Host "Report written to: $ReportPath" -ForegroundColor Green
