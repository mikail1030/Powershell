# Define the root path containing the home drives
$RootPath = "G:\private"

# Get all top-level subfolders (excluding files)
$HomeFolders = Get-ChildItem -Path $RootPath -Directory

foreach ($Folder in $HomeFolders) {
    $FolderName = $Folder.Name
    $FolderPath = $Folder.FullName
    
    Write-Host "`n==================================================" -ForegroundColor Cyan
    Write-Host "START PROCESSING: $FolderName" -ForegroundColor Cyan
    Write-Host "Folder Path: $FolderPath"
    Write-Host "==================================================" -ForegroundColor Cyan
    
    # 1. Set the Owner of the folder to the User
    try {
        # Create a new NTAccount object for the user
        $Account = New-Object System.Security.Principal.NTAccount($FolderName)
        
        # Get current ACL
        $Acl = Get-Acl -Path $FolderPath
        
        # Set the owner
        $Acl.SetOwner($Account)
        Set-Acl -Path $FolderPath -AclObject $Acl
        Write-Host "[SUCCESS] Set owner to: $FolderName" -ForegroundColor Green
    }
    catch {
        Write-Warning "[ERROR] Failed to set owner for $FolderName. Reason: $_"
    }

    # 2. Grant Full Control Permissions
    try {
        # Refresh ACL object
        $Acl = Get-Acl -Path $FolderPath
        
        # Define the access rule: User, FullControl, Allow inheritance to subfolders and files
        $InheritanceFlags = [System.Security.AccessControl.InheritanceFlags]"ContainerInherit, ObjectInherit"
        $PropagationFlags = [System.Security.AccessControl.PropagationFlags]"None"
        $AccessType = [System.Security.AccessControl.AccessControlType]"Allow"
        
        $AccessRule = New-Object System.Security.AccessControl.FileSystemAccessRule(
            $FolderName, 
            "FullControl", 
            $InheritanceFlags, 
            $PropagationFlags, 
            $AccessType
        )
        
        # Add the rule to the ACL and apply it
        $Acl.SetAccessRule($AccessRule)
        Set-Acl -Path $FolderPath -AclObject $Acl
        Write-Host "[SUCCESS] Granted Full Control to: $FolderName" -ForegroundColor Green
    }
    catch {
        Write-Warning "[ERROR] Failed to set Full Control for $FolderName. Reason: $_"
    }

    # Pause after each user to inspect results
    Write-Host ""
    Read-Host -Prompt "Finished processing user '$FolderName'. Press ENTER to proceed to the next folder, or Ctrl+C to abort"
}

Write-Host "`n==================================================" -ForegroundColor Cyan
Write-Host "Script execution completed." -ForegroundColor Cyan

