<#
.SYNOPSIS
    Recursively sets owner to BUILTIN\Administrators for all folders/subfolders.
.NOTES
    Run this from an elevated (Administrator) PowerShell session.
    The account running this needs SeTakeOwnershipPrivilege (local admins have it by default).
#>

param(
    [string]$RootPath = "D:\CA_Backup",
    [switch]$IncludeFiles  # also take ownership of files, not just folders
)

if (-not (Test-Path $RootPath)) {
    Write-Error "Path '$RootPath' does not exist."
    return
}

$owner = New-Object System.Security.Principal.NTAccount("BUILTIN\Administrators")

function Set-Owner {
    param([string]$Path)
    try {
        $acl = Get-Acl -Path $Path
        $acl.SetOwner($owner)
        Set-Acl -Path $Path -AclObject $acl -ErrorAction Stop
        Write-Host "OK: $Path"
    }
    catch {
        Write-Warning "Failed (Set-Acl) on $Path - trying takeown.exe fallback. Error: $($_.Exception.Message)"
        # Fallback for cases where Set-Acl can't take ownership due to broken ACL chains
        try {
            $arg = if ((Get-Item $Path) -is [System.IO.DirectoryInfo]) { "/D Y" } else { "" }
            takeown.exe /F "$Path" /A $arg | Out-Null
            $acl = Get-Acl -Path $Path
            $acl.SetOwner($owner)
            Set-Acl -Path $Path -AclObject $acl
            Write-Host "OK (via takeown): $Path"
        }
        catch {
            Write-Error "FAILED: $Path - $($_.Exception.Message)"
        }
    }
}

# Set owner on the root itself
Set-Owner -Path $RootPath

# Get all folders (and optionally files), deepest first is not required for owner-setting,
# but we process top-down which works fine for ownership.
$items = Get-ChildItem -Path $RootPath -Recurse -Force -ErrorAction SilentlyContinue -Directory

foreach ($folder in $items) {
    Set-Owner -Path $folder.FullName
}

if ($IncludeFiles) {
    $files = Get-ChildItem -Path $RootPath -Recurse -Force -ErrorAction SilentlyContinue -File
    foreach ($file in $files) {
        Set-Owner -Path $file.FullName
    }
}

Write-Host "`nDone."
