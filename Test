# ============================================================
#  CONFIGURATION â€” edit these two lines before running
# ============================================================
$AccountsFile = "C:\Path\To\accounts.txt"   # TXT file with one account name per line
$SearchDirectory = "C:\Path\To\Folders"     # Directory to search for matching folders
# ============================================================

# --- Validate inputs ---
if (-not (Test-Path $AccountsFile)) {
    Write-Error "Accounts file not found: $AccountsFile"
    exit 1
}

if (-not (Test-Path $SearchDirectory)) {
    Write-Error "Search directory not found: $SearchDirectory"
    exit 1
}

# --- Load accounts (skip blank lines and trim whitespace) ---
$accounts = Get-Content $AccountsFile |
    Where-Object { $_.Trim() -ne "" } |
    ForEach-Object { $_.Trim() }

if ($accounts.Count -eq 0) {
    Write-Warning "No accounts found in $AccountsFile. Exiting."
    exit 0
}

Write-Host "`nLoaded $($accounts.Count) account(s) from file." -ForegroundColor Cyan
Write-Host "Scanning: $SearchDirectory`n" -ForegroundColor Cyan

$deleted  = 0
$notFound = 0

foreach ($account in $accounts) {
    $folderPath = Join-Path $SearchDirectory $account

    if (Test-Path $folderPath -PathType Container) {
        try {
            Remove-Item -Path $folderPath -Recurse -Force
            Write-Host "[DELETED]   $folderPath" -ForegroundColor Green
            $deleted++
        }
        catch {
            Write-Host "[ERROR]     $folderPath â€” $($_.Exception.Message)" -ForegroundColor Red
        }
    }
    else {
        Write-Host "[NOT FOUND] $account" -ForegroundColor Yellow
        $notFound++
    }
}

# --- Summary ---
Write-Host "`n--- Done ---" -ForegroundColor Cyan
Write-Host "Deleted  : $deleted folder(s)" -ForegroundColor Green
Write-Host "Not found: $notFound account(s)" -ForegroundColor Yellow
